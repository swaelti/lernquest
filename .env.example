# LernQuest Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.

# PFLICHT: Zufälliger Schlüssel für Session-Verschlüsselung
SECRET_KEY=change-me-to-a-random-string

# Git-URL des Content-Repos (Standard: offizielles Repo)
CONTENT_REPO=https://github.com/simonx/lernquest-content

# Automatischer Content-Sync: off | daily | weekly
AUTO_SYNC=off

# Öffentliche URL der Instanz
BASE_URL=http://localhost:8080

# Port (Standard: 8080)
PORT=8080

# Log-Level: debug | info | warn | error
LOG_LEVEL=info

# Hinter Reverse Proxy (Caddy, Nginx)?
TRUST_PROXY=false
