{
  "name": "lernquest",
  "version": "0.1.0",
  "description": "Gamifizierte Lernplattform für Schweizer Informatik-Berufsschüler",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node dist/server.js",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "content:validate": "tsx src/services/content-validator.ts",
    "content:sync": "tsx src/services/sync.ts"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/session": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/formbody": "^8.0.0",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.0",
    "yaml": "^2.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "bcryptjs": "^2.4.3",
    "nanoid": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/bcryptjs": "^2.4.0",
    "drizzle-kit": "^0.30.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "AGPL-3.0",
  "author": "Simon",
  "repository": {
    "type": "git",
    "url": "https://github.com/simonx/lernquest"
  }
}
